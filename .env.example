# Copy to .env and adjust. Never commit .env.

# --- Django ---
DJANGO_SECRET_KEY=change-me-in-prod-use-a-long-random-string
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,api
# Comma-separated origins allowed to call the API (the Next.js frontend)
DJANGO_CORS_ALLOWED_ORIGINS=http://localhost:3000

# Public base URL of the guest frontend (used to build QR-code target URLs)
FRONTEND_BASE_URL=http://localhost:3000

# --- PostgreSQL (pgvector) ---
POSTGRES_DB=facefolio
POSTGRES_USER=facefolio
POSTGRES_PASSWORD=facefolio
POSTGRES_HOST=db
POSTGRES_PORT=5432

# --- Redis / Celery ---
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1

# --- MinIO / S3 object storage ---
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
# Bucket photos are stored in
S3_BUCKET_NAME=facefolio-photos
# Internal endpoint the API/worker use to reach MinIO (service name)
S3_ENDPOINT_URL=http://minio:9000
# Public endpoint browsers use for presigned URLs (host-reachable)
S3_PUBLIC_ENDPOINT_URL=http://localhost:9100
S3_REGION=us-east-1

# --- Domain config ---
# Default retention period for an event's photos + face index, in days
DEFAULT_EVENT_RETENTION_DAYS=90
# Max photos a guest can bundle into one ZIP download
MAX_BULK_DOWNLOAD=100
