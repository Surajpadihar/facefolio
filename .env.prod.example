# Production env. Copy to .env on the server and fill in the REAL values.
#   cp .env.prod.example .env  &&  nano .env
# Generate a secret key:  python3 -c "import secrets;print(secrets.token_urlsafe(64))"

# === YOUR DOMAIN (set this everywhere it appears) ===
# e.g. facefolio.duckdns.org  (a free DuckDNS subdomain pointed at the VM's public IP)
DOMAIN=CHANGE-ME.duckdns.org
PUBLIC_BASE_URL=https://CHANGE-ME.duckdns.org

# --- Django ---
DJANGO_SECRET_KEY=CHANGE-ME-long-random-string
DJANGO_DEBUG=false
DJANGO_BEHIND_PROXY=true
DJANGO_ALLOWED_HOSTS=CHANGE-ME.duckdns.org,api,localhost
DJANGO_CORS_ALLOWED_ORIGINS=https://CHANGE-ME.duckdns.org
DJANGO_CSRF_TRUSTED_ORIGINS=https://CHANGE-ME.duckdns.org
FRONTEND_BASE_URL=https://CHANGE-ME.duckdns.org

# --- PostgreSQL (pgvector) ---
POSTGRES_DB=facefolio
POSTGRES_USER=facefolio
POSTGRES_PASSWORD=CHANGE-ME-strong-db-password
POSTGRES_HOST=db
POSTGRES_PORT=5432

# --- Redis / Celery ---
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1

# --- MinIO / S3 object storage ---
MINIO_ROOT_USER=CHANGE-ME-minio-user
MINIO_ROOT_PASSWORD=CHANGE-ME-strong-minio-password
S3_BUCKET_NAME=facefolio-photos
S3_ENDPOINT_URL=http://minio:9000
# Photos are served to browsers via Caddy under this domain's /facefolio-photos/ path:
S3_PUBLIC_ENDPOINT_URL=https://CHANGE-ME.duckdns.org
S3_REGION=us-east-1

# --- Domain config ---
DEFAULT_EVENT_RETENTION_DAYS=90
MAX_BULK_DOWNLOAD=100
MAX_UPLOAD_BATCH=60
MAX_UPLOAD_FILE_MB=30
